# =========================================================
# Clean URL configuration (hide .html extensions)
# =========================================================
RewriteEngine On

# 1. Collapse /index and /index.html to the site root.
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index(\.html)?[\ ?] [NC]
RewriteRule ^ / [R=301,L]

# 2. If a request is made directly for a .html file, redirect
#    (301) to the clean URL without the extension.
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^.]+)\.html[\ ?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 3. Internally serve the matching .html file for clean URLs,
#    without changing what appears in the address bar.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^([^.]+)$ $1.html [NC,L]

# Custom error page
ErrorDocument 404 /404.html

# Default document
DirectoryIndex index.html
